# Porta do servidor
PORT=3001

# Google Cloud Vision (OCR de placa)
GOOGLE_VISION_KEY=sua_chave_aqui

# API veicular (APIBrasil)
APIBRASIL_TOKEN=seu_token_aqui
APIBRASIL_DEVICE_TOKEN=seu_device_token_aqui

# WhatsApp (Meta Cloud API)
WHATSAPP_TOKEN=seu_token_meta_aqui
WHATSAPP_PHONE_ID=id_do_numero_whatsapp

# Banco de dados (quando migrar do mock para PostgreSQL)
# DATABASE_URL=postgresql://usuario:senha@localhost:5432/autocontrol
